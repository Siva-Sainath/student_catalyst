{
  "expo": {
    "name": "Campus AI MVP",
    "slug": "campus-ai-mvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app requires microphone access to enable voice commands for the AI agent."
      }
    },
    "android": {
      "package": "com.college.portal.mvp",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:8000"
    }
  }
}
